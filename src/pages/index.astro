---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Chat de Cerâmica com IA Local">
  <div class="hero">
    <div class="badge">🧠 190 conhecimentos indexados</div>

    <h1>ANARI OS</h1>
    <p>
      Uma inteligência artificial que corre num mini-PC em Penafiel.<br/>
      Criada por um ceramista. Para ceramistas.
    </p>

    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.6rem; max-width: 300px; margin: 0 auto;">
      <a href="/auth/login" style="display: block; width: 100%; padding: 0.85rem; background: var(--text); color: var(--bg); text-align: center; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: all 0.15s;">
        Entrar na Plataforma
      </a>
      <a href="/auth/register" style="display: block; width: 100%; padding: 0.75rem; background: transparent; color: var(--text-secondary); text-align: center; border-radius: 8px; text-decoration: none; font-weight: 500; font-size: 0.85rem; border: 1px solid var(--border); transition: all 0.15s;">
        Criar Conta Gratuita
      </a>
    </div>
  </div>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 5rem 0 3rem;
  }
  .badge {
    display: inline-block;
    background: var(--accent-subtle);
    color: var(--accent);
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }
  .hero p {
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 460px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  @media (max-width: 640px) {
    .hero { padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; }
  }
</style>

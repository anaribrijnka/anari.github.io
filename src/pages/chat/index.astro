---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Chat de Cerâmica — ANARI OS">
  <div style="max-width: 700px; margin: 0 auto;">
    <h1 style="font-size: 1.5rem; margin-bottom: 0.5rem;">💬 Chat de Cerâmica</h1>
    <p class="subtitle" style="font-size: 0.85rem; margin-bottom: 1.5rem;">Pergunta o que quiseres sobre cerâmica. Respostas instantâneas com 190 conhecimentos indexados.</p>

    <div class="chat-container">
      <div class="chat-messages" id="messages">
        <p id="welcome-msg" style="color: var(--text-secondary); text-align: center; margin-top: 120px; font-size: 0.85rem;">
          Olá! Pergunta algo sobre cerâmica...
        </p>
      </div>
      <div class="chat-input-bar">
        <input type="text" id="user-input" placeholder="Ex: O que é a temperatura de cone 10?" />
        <button onclick="sendMessage()" class="btn" style="padding: 0.6rem 1.2rem; font-size: 0.85rem;">Enviar</button>
      </div>
    </div>

    <p style="margin-top: 1.5rem; font-size: 0.75rem; color: var(--text-secondary); text-align: center;">
      <strong>Tópicos:</strong> esmaltes · vidrados · cozedura · materiais · argilas · fornos · temperaturas · defeitos · formulações
    </p>
  </div>
</Layout>

<style>
  .chat-container {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .chat-messages {
    padding: 1.25rem;
    min-height: 380px;
    max-height: 480px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .chat-input-bar {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
  }
  .chat-input-bar input {
    flex: 1;
    background: var(--bg-card);
  }
  .msg-user {
    text-align: right;
    color: var(--text);
    font-size: 0.85rem;
  }
  .msg-anari {
    background: #111113;
    border: 1px solid #1e1e22;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    color: #a0a0a8;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .msg-loading {
    color: #555;
    font-size: 0.8rem;
    font-style: italic;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    background: var(--text);
    color: var(--bg);
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.85rem;
    border: none;
    cursor: pointer;
    transition: all 0.15s;
    font-family: var(--font);
  }
  .btn:hover {
    background: #ccc;
  }
</style>

<script>
  const API = 'http://localhost:8000/run';
  const token = localStorage.getItem('anari_token');
  const user = localStorage.getItem('anari_user');

  if (!token) {
    window.location.href = '/anari.github.io/auth/login';
  } else {
    document.getElementById('welcome-msg').textContent = 'Olá ' + (user || 'Ceramista') + '! Pergunta algo sobre cerâmica...';
  }

  async function sendMessage() {
    const input = document.getElementById('user-input');
    const messages = document.getElementById('messages');
    const msg = input.value.trim();
    if (!msg) return;

    // Mostrar pergunta
    messages.innerHTML += `<div class="msg-user"><strong>Tu:</strong> ${msg}</div>`;
    input.value = '';
    messages.innerHTML += `<div class="msg-loading">A pesquisar nos 190 conhecimentos...</div>`;
    messages.scrollTop = messages.scrollHeight;

    try {
      const res = await fetch(API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, source: 'site', mode: 'execute' })
      });
      const events = await res.json();
      const final = events.find(e => e.type === 'final');
      const reply = final?.result || 'Erro de ligação.';

      // Remover loading
      messages.removeChild(messages.lastChild);
      messages.innerHTML += `<div class="msg-anari"><strong>ANARI:</strong><br/>${reply}</div>`;
      messages.scrollTop = messages.scrollHeight;
    } catch {
      messages.removeChild(messages.lastChild);
      messages.innerHTML += `<div class="msg-anari" style="color: #f87171;">Erro de ligação ao servidor. O backend está a correr?</div>`;
    }
  }

  document.getElementById('user-input').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendMessage();
  });
</script>
